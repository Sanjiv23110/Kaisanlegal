# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT signing secret — generate a strong random string (e.g. `openssl rand -hex 32`)
SECRET_KEY=your_very_long_random_secret_key_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Dev default is http://localhost:3000; set your production domain here when deploying
ALLOWED_ORIGINS=http://localhost:3000
